{
  "hosting": {
    "site": "whisperkey-app",
    "public": "public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "headers": [
      {
        "source": "**/*.@(js|css)",
        "headers": [
          { "key": "Cache-Control", "value": "max-age=31536000" }
        ]
      },
      {
        "source": "*.dmg",
        "headers": [
          { "key": "Content-Disposition", "value": "attachment" }
        ]
      }
    ]
  }
}
